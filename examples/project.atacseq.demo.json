{
  "workflow": {
    "type": "atacseq",
    "label": "ATAC-seq"
  },
  "project": {
    "id": "atacseq_demo_001",
    "name": "ATAC-seq demo",
    "description": "Demo ATAC-seq project configuration."
  },
  "server": {
    "host": "hpc.example.edu",
    "user": "username",
    "scheduler": "slurm",
    "remote_base_dir": "/data/users/username/omic_projects",
    "remote_workdir": "/data/users/username/omic_projects/atacseq_demo_001",
    "threads": 16,
    "memory_gb": 64,
    "shell": "bash",
    "init_commands": [
      "source ~/miniconda3/etc/profile.d/conda.sh",
      "conda activate epigenome"
    ]
  },
  "sequencing": {
    "layout": "paired",
    "reads_per_sample_million": 50
  },
  "samples": {
    "local_data_dir": "D:/data/atacseq/raw_fastq",
    "remote_data_dir": "/data/users/username/omic_projects/atacseq_demo_001/raw",
    "items": [
      {
        "sample_id": "ATAC_Tumor_1",
        "fastq_1": "ATAC_Tumor_1_R1.fastq.gz",
        "fastq_2": "ATAC_Tumor_1_R2.fastq.gz",
        "replicate": 1
      },
      {
        "sample_id": "ATAC_Normal_1",
        "fastq_1": "ATAC_Normal_1_R1.fastq.gz",
        "fastq_2": "ATAC_Normal_1_R2.fastq.gz",
        "replicate": 1
      }
    ]
  },
  "execution": {
    "backend": "bash",
    "nfcore": {
      "pipeline": "nf-core/atacseq",
      "revision": "2.1.2",
      "profile": "singularity",
      "params": {},
      "extra_args": ""
    }
  },
  "reference": {
    "genome_size": "hs",
    "bowtie2_index_prefix": "/data/ref/genomes/GRCh38/bowtie2/GRCh38",
    "chromosome_sizes_path": "/data/ref/genomes/GRCh38/GRCh38.chrom.sizes",
    "blacklist_bed_path": "/data/ref/genomes/GRCh38/ENCFF356LFX.bed",
    "nfcore_genome": "GRCh38"
  },
  "notification": {
    "email_enabled": false
  }
}
